<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VintFlow — Vends 3x plus vite sur Vinted</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --p:#6366F1;--p2:#4F46E5;--p3:#EEF2FF;
  --dark:#0F172A;--green:#22C55E;--green2:#16A34A;
  --bg:#F8FAFC;--white:#fff;--border:#E2E8F0;
  --mu:#64748B;--red:#EF4444;--amber:#F59E0B;
  --fh:'Sora',sans-serif;--fb:'DM Sans',sans-serif;--r:12px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--dark);font-family:var(--fb);font-weight:300;overflow-x:hidden}

/* ── UTILS ── */
.hidden{display:none!important}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pop{0%{transform:scale(0)}80%{transform:scale(1.1)}100%{transform:scale(1)}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
.anim{animation:fadeUp .5s ease both}
.d1{animation-delay:.05s}.d2{animation-delay:.1s}.d3{animation-delay:.15s}.d4{animation-delay:.2s}.d5{animation-delay:.25s}
.spinner{width:18px;height:18px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;display:inline-block;vertical-align:middle}

/* ── BUTTONS ── */
.btn{padding:11px 22px;border-radius:var(--r);font-size:14px;font-weight:500;border:none;cursor:pointer;font-family:var(--fb);transition:all .2s;display:inline-flex;align-items:center;gap:7px;text-decoration:none;letter-spacing:.01em;white-space:nowrap}
.btn-p{background:var(--p);color:#fff;box-shadow:0 2px 8px rgba(99,102,241,.3)}
.btn-p:hover{background:var(--p2);transform:translateY(-1px);box-shadow:0 4px 16px rgba(99,102,241,.4)}
.btn-g{background:var(--green);color:#fff;box-shadow:0 2px 8px rgba(34,197,94,.3)}
.btn-g:hover{background:var(--green2);transform:translateY(-1px);box-shadow:0 4px 16px rgba(34,197,94,.4)}
.btn-ol{background:transparent;color:var(--dark);border:1.5px solid var(--border)}
.btn-ol:hover{border-color:var(--p);color:var(--p)}
.btn-ghost{background:rgba(99,102,241,.08);color:var(--p)}
.btn-ghost:hover{background:rgba(99,102,241,.15)}
.btn-sm{padding:7px 14px;font-size:12px;border-radius:9px}
.btn-full{width:100%;justify-content:center}
.btn-dark{background:var(--dark);color:#fff}
.btn-dark:hover{background:#1E293B;transform:translateY(-1px)}

/* ── VIEWS ── */
#view-landing,#view-app{display:none}
#view-landing.show,#view-app.show{display:block}

/* ══════════════════════════
   LANDING PAGE
══════════════════════════ */
.lnav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(248,250,252,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.lnav-in{max-width:1080px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:62px;padding:0 24px}
.lnav-logo{font-family:var(--fh);font-size:20px;font-weight:700;color:var(--dark);display:flex;align-items:center;gap:8px;cursor:pointer}
.logo-dot{width:8px;height:8px;border-radius:50%;background:var(--p)}
.lnav-r{display:flex;gap:8px;align-items:center}
.lnav-link{font-size:13px;color:var(--mu);cursor:pointer;padding:7px 12px;border-radius:8px;transition:.2s;font-weight:400}
.lnav-link:hover{color:var(--dark);background:rgba(0,0,0,.04)}

/* Hero */
.hero{padding:120px 24px 80px;max-width:1080px;margin:0 auto;text-align:center}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:var(--p3);color:var(--p);font-size:12px;font-weight:600;padding:6px 14px;border-radius:20px;margin-bottom:28px;letter-spacing:.02em}
.hero-badge span{width:6px;height:6px;border-radius:50%;background:var(--p);animation:pulse 1.5s infinite}
.hero h1{font-family:var(--fh);font-size:58px;font-weight:800;line-height:1.05;letter-spacing:-.03em;margin-bottom:18px;color:var(--dark)}
.hero h1 em{font-style:normal;color:var(--p)}
.hero-sub{font-size:18px;color:var(--mu);line-height:1.7;max-width:520px;margin:0 auto 36px;font-weight:300}
.hero-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:20px}
.hero-note{font-size:12px;color:var(--mu)}
/* App preview mockup */
.hero-preview{max-width:780px;margin:52px auto 0;background:var(--white);border:1px solid var(--border);border-radius:18px;box-shadow:0 20px 60px rgba(15,23,42,.1);overflow:hidden}
.hp-bar{background:var(--dark);padding:12px 16px;display:flex;align-items:center;gap:8px}
.hp-dot{width:10px;height:10px;border-radius:50%}
.hp-content{padding:24px;display:grid;grid-template-columns:220px 1fr;gap:16px;min-height:220px}
.hp-sidebar{background:var(--bg);border-radius:10px;padding:14px}
.hp-s-item{padding:8px 10px;border-radius:7px;font-size:11px;font-weight:500;color:var(--mu);display:flex;align-items:center;gap:7px;margin-bottom:3px}
.hp-s-item.active{background:var(--p3);color:var(--p)}
.hp-main{display:flex;flex-direction:column;gap:10px}
.hp-card{background:var(--bg);border-radius:10px;padding:14px}
.hp-label{font-size:9px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--mu);margin-bottom:6px}
.hp-text{font-size:11px;color:var(--dark);line-height:1.6}
.hp-score{background:linear-gradient(135deg,var(--p3),#F0FDF4);border-radius:10px;padding:14px;display:flex;align-items:center;justify-content:space-between}
.hp-score-val{font-family:var(--fh);font-size:26px;font-weight:800;color:var(--p)}
.hp-score-lbl{font-size:10px;color:var(--mu);font-weight:500}

/* Sections */
.section{padding:80px 24px;max-width:1080px;margin:0 auto}
.section-tag{display:inline-flex;align-items:center;gap:6px;background:var(--p3);color:var(--p);font-size:11px;font-weight:600;padding:5px 12px;border-radius:20px;margin-bottom:16px;letter-spacing:.05em}
.section-h{font-family:var(--fh);font-size:40px;font-weight:800;line-height:1.1;letter-spacing:-.02em;margin-bottom:12px;color:var(--dark)}
.section-h em{font-style:normal;color:var(--p)}
.section-sub{font-size:16px;color:var(--mu);max-width:500px;line-height:1.7}

/* Problem cards */
.prob-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px}
.prob-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px;transition:.2s}
.prob-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(15,23,42,.08);border-color:rgba(99,102,241,.25)}
.prob-ico{font-size:28px;margin-bottom:14px}
.prob-t{font-family:var(--fh);font-size:16px;font-weight:700;margin-bottom:7px}
.prob-d{font-size:13px;color:var(--mu);line-height:1.65}

/* Features */
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px}
.feat-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px;position:relative;overflow:hidden;transition:.2s}
.feat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--p),#8B5CF6)}
.feat-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(99,102,241,.12)}
.feat-n{font-family:var(--fh);font-size:15px;font-weight:700;margin-bottom:7px}
.feat-d{font-size:13px;color:var(--mu);line-height:1.65}
.feat-ico{font-size:24px;margin-bottom:13px}

/* Pricing */
.price-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:700px;margin:40px auto 0}
.price-card{background:var(--white);border:2px solid var(--border);border-radius:20px;padding:28px;transition:.2s;position:relative}
.price-card.pop{border-color:var(--p);box-shadow:0 8px 32px rgba(99,102,241,.15)}
.pop-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--p);color:#fff;font-size:11px;font-weight:600;padding:4px 14px;border-radius:20px;white-space:nowrap}
.price-name{font-family:var(--fh);font-size:16px;font-weight:700;margin-bottom:6px}
.price-val{font-family:var(--fh);font-size:42px;font-weight:800;color:var(--dark);line-height:1;margin-bottom:4px}
.price-val span{font-size:16px;font-weight:400;color:var(--mu)}
.price-desc{font-size:12px;color:var(--mu);margin-bottom:20px}
.price-sep{height:1px;background:var(--border);margin-bottom:16px}
.price-feat{display:flex;align-items:center;gap:8px;font-size:13px;margin-bottom:9px;color:var(--dark)}
.pf-ok{color:var(--green);font-weight:600;font-size:14px}
.pf-no{color:var(--border);font-weight:600;font-size:14px}

/* Footer */
.footer{background:var(--dark);padding:40px 24px;text-align:center;color:rgba(255,255,255,.5);font-size:13px}
.footer-logo{font-family:var(--fh);font-size:18px;font-weight:700;color:#fff;margin-bottom:10px;display:flex;align-items:center;gap:7px;justify-content:center}

/* ══════════════════════════
   APP / DASHBOARD
══════════════════════════ */
#view-app{min-height:100vh;display:flex;flex-direction:column}
.app-wrap{display:flex;flex:1;min-height:100vh}

/* App Topbar */
.app-top{background:var(--white);border-bottom:1px solid var(--border);padding:0 20px;height:58px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;flex-shrink:0}
.at-logo{font-family:var(--fh);font-size:17px;font-weight:700;color:var(--dark);display:flex;align-items:center;gap:7px;cursor:pointer}
.at-r{display:flex;gap:9px;align-items:center}
.plan-badge{background:var(--p3);color:var(--p);font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px}
.plan-badge.premium{background:#FEF3C7;color:#D97706}
.usage-text{font-size:12px;color:var(--mu)}
.avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--p),#8B5CF6);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;color:#fff;cursor:pointer;flex-shrink:0}

/* Sidebar */
.sidebar{width:220px;background:var(--white);border-right:1px solid var(--border);padding:16px 12px;display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:58px;height:calc(100vh - 58px);overflow-y:auto}
.sb-item{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:9px;font-size:13px;color:var(--mu);cursor:pointer;transition:.15s;user-select:none;margin-bottom:2px;font-weight:400}
.sb-item:hover{background:var(--bg);color:var(--dark)}
.sb-item.ac{background:var(--p3);color:var(--p);font-weight:500}
.sb-ico{font-size:15px;opacity:.75;flex-shrink:0}
.sb-sep{height:1px;background:var(--border);margin:10px 4px}
.sb-label{font-size:9px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--mu);padding:8px 12px 4px}
.sb-upgrade{background:linear-gradient(135deg,var(--p3),#F0FDF4);border:1px solid rgba(99,102,241,.15);border-radius:10px;padding:13px;margin-top:auto}
.sb-up-t{font-size:12px;font-weight:600;color:var(--dark);margin-bottom:5px}
.sb-up-d{font-size:11px;color:var(--mu);margin-bottom:10px;line-height:1.5}

/* Main content */
.main-content{flex:1;overflow-y:auto;padding:24px}
.page-app{display:none;animation:fadeUp .35s ease}
.page-app.ac{display:block}

/* ── GENERATE PAGE ── */
.gen-layout{display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start}
.gen-form-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px}
.gen-result-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px;position:sticky;top:24px}
.card-title{font-family:var(--fh);font-size:16px;font-weight:700;margin-bottom:18px;display:flex;align-items:center;gap:8px}
.fg{margin-bottom:14px}
.fg label{font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--mu);display:block;margin-bottom:5px}
.fi{width:100%;border:1.5px solid var(--border);border-radius:9px;padding:10px 13px;font-family:var(--fb);font-size:13px;color:var(--dark);background:var(--bg);outline:none;transition:.2s}
.fi:focus{border-color:var(--p);background:var(--white);box-shadow:0 0 0 3px rgba(99,102,241,.08)}
.fi option{background:var(--white)}
.fi-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fi-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}

/* Result blocks */
.result-empty{text-align:center;padding:32px 16px}
.re-ico{font-size:42px;margin-bottom:12px}
.re-t{font-family:var(--fh);font-size:16px;font-weight:700;margin-bottom:6px}
.re-d{font-size:13px;color:var(--mu);line-height:1.6}
.result-content{display:none}
.result-content.show{display:block;animation:fadeUp .4s ease}
.res-block{background:var(--bg);border-radius:10px;padding:14px;margin-bottom:12px;position:relative}
.rb-label{font-size:9px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--mu);margin-bottom:7px;display:flex;justify-content:space-between;align-items:center}
.rb-copy{font-size:10px;background:var(--white);border:1px solid var(--border);padding:3px 9px;border-radius:6px;cursor:pointer;color:var(--mu);transition:.15s;font-family:var(--fb);font-weight:500}
.rb-copy:hover{border-color:var(--p);color:var(--p)}
.rb-copy.copied{background:var(--green);border-color:var(--green);color:#fff}
.rb-text{font-size:13px;color:var(--dark);line-height:1.65;white-space:pre-wrap}
.rb-title{font-family:var(--fh);font-size:16px;font-weight:700;color:var(--dark);line-height:1.4}
.rb-price{font-family:var(--fh);font-size:28px;font-weight:800;color:var(--p)}
.rb-price-note{font-size:11px;color:var(--mu);margin-top:3px}
.tags-wrap{display:flex;flex-wrap:wrap;gap:5px;margin-top:4px}
.tag{background:var(--p3);color:var(--p);font-size:11px;padding:3px 9px;border-radius:20px;font-weight:500}
.score-row{display:flex;align-items:center;justify-content:space-between}
.score-circle{width:56px;height:56px;border-radius:50%;background:conic-gradient(var(--green) var(--pct,0%), var(--border) 0%);display:flex;align-items:center;justify-content:center;position:relative}
.score-inner{width:42px;height:42px;border-radius:50%;background:var(--bg);display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:13px;font-weight:800;color:var(--dark)}
.score-label{font-size:12px;color:var(--mu)}
.score-feedback{font-size:12px;color:var(--green);font-weight:500}

/* Loading shimmer */
.shimmer{background:linear-gradient(90deg,var(--bg) 25%,var(--border) 50%,var(--bg) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:7px;height:14px;margin-bottom:8px}
.sh-t{height:18px;width:70%}
.sh-d{height:12px}.sh-d2{height:12px;width:85%}.sh-d3{height:12px;width:60%}

/* ── DASHBOARD HOME ── */
.dash-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
.dash-mc{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:18px}
.dm-l{font-size:10px;color:var(--mu);text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px;font-weight:500}
.dm-v{font-family:var(--fh);font-size:28px;font-weight:800;color:var(--dark);line-height:1}
.dm-s{font-size:11px;color:var(--mu);margin-top:5px}
.dash-g2{display:grid;grid-template-columns:1.5fr 1fr;gap:12px}
.recent-item{display:flex;align-items:flex-start;gap:10px;padding:11px 0;border-bottom:1px solid var(--border)}
.recent-item:last-child{border-bottom:none}
.ri-ico{width:34px;height:34px;border-radius:8px;background:var(--p3);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.ri-t{font-size:13px;font-weight:500;color:var(--dark);margin-bottom:2px;line-height:1.3}
.ri-s{font-size:11px;color:var(--mu)}
.ri-score{font-size:11px;font-weight:600;color:var(--green);margin-left:auto;white-space:nowrap;flex-shrink:0}
.tip-item{background:var(--bg);border-radius:9px;padding:12px;margin-bottom:8px}
.tip-t{font-size:12px;font-weight:600;margin-bottom:3px}
.tip-d{font-size:11px;color:var(--mu);line-height:1.55}

/* ── HISTORY PAGE ── */
.hist-grid{display:grid;gap:10px}
.hist-card{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:18px;transition:.15s}
.hist-card:hover{border-color:rgba(99,102,241,.3);box-shadow:0 4px 16px rgba(99,102,241,.08)}
.hc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
.hc-title{font-family:var(--fh);font-size:14px;font-weight:700;color:var(--dark);line-height:1.35;flex:1;padding-right:10px}
.hc-score{font-size:11px;font-weight:600;color:var(--green);background:#F0FDF4;padding:3px 8px;border-radius:20px;white-space:nowrap;flex-shrink:0}
.hc-desc{font-size:12px;color:var(--mu);line-height:1.6;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.hc-meta{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px}
.hc-tag{font-size:10px;background:var(--bg);color:var(--mu);padding:2px 8px;border-radius:5px;border:1px solid var(--border);font-weight:500}
.hc-price{font-family:var(--fh);font-size:18px;font-weight:800;color:var(--p)}
.hc-actions{display:flex;gap:7px}
.empty-state{text-align:center;padding:60px 20px}
.es-ico{font-size:52px;margin-bottom:16px}
.es-t{font-family:var(--fh);font-size:22px;font-weight:700;margin-bottom:8px}
.es-d{font-size:14px;color:var(--mu);line-height:1.6;max-width:340px;margin:0 auto 24px}

/* ── SETTINGS ── */
.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.settings-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:24px}
.sc-t{font-family:var(--fh);font-size:15px;font-weight:700;margin-bottom:16px}
.srow{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:1px solid var(--border)}
.srow:last-child{border-bottom:none}
.sr-l{font-size:13px;font-weight:500}
.sr-d{font-size:11px;color:var(--mu);margin-top:2px}

/* ── UPGRADE MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.6);z-index:500;display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.show{display:flex;animation:fadeIn .2s ease}
.modal{background:var(--white);border-radius:20px;padding:32px;max-width:440px;width:100%;box-shadow:0 20px 60px rgba(15,23,42,.2);animation:fadeUp .3s ease}
.modal-ico{font-size:44px;text-align:center;margin-bottom:16px;animation:pop .5s ease}
.modal-t{font-family:var(--fh);font-size:24px;font-weight:800;text-align:center;margin-bottom:8px}
.modal-d{font-size:14px;color:var(--mu);text-align:center;line-height:1.65;margin-bottom:24px}
.modal-feats{background:var(--bg);border-radius:12px;padding:16px;margin-bottom:20px}
.mf-item{display:flex;align-items:center;gap:9px;font-size:13px;margin-bottom:9px}
.mf-item:last-child{margin-bottom:0}
.mf-ok{color:var(--green);font-weight:700}
.modal-btns{display:flex;flex-direction:column;gap:8px}
.modal-close{position:absolute;top:16px;right:16px;cursor:pointer;font-size:20px;color:var(--mu);background:none;border:none}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;right:24px;background:var(--dark);color:#fff;padding:12px 18px;border-radius:12px;font-size:13px;font-weight:500;z-index:999;display:flex;align-items:center;gap:8px;box-shadow:0 8px 24px rgba(15,23,42,.25);animation:fadeUp .3s ease;max-width:320px}
.toast.success{background:var(--green)}
.toast.error{background:var(--red)}

/* ── PAGE TITLES ── */
.page-hd{margin-bottom:22px}
.ph-t{font-family:var(--fh);font-size:24px;font-weight:800;color:var(--dark);margin-bottom:4px}
.ph-d{font-size:14px;color:var(--mu)}

/* Limit bar */
.limit-bar{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;gap:14px}
.lb-track{flex:1;height:6px;background:var(--bg);border-radius:3px;overflow:hidden}
.lb-fill{height:100%;background:var(--p);border-radius:3px;transition:width .5s}
.lb-fill.warn{background:var(--amber)}
.lb-fill.full{background:var(--red)}
.lb-text{font-size:12px;color:var(--mu);white-space:nowrap}
.lb-text strong{color:var(--dark)}

/* ── RESPONSIVE MOBILE ── */
@media(max-width:768px){
  .hero h1{font-size:36px}
  .prob-grid,.feat-grid,.gen-layout,.settings-grid{grid-template-columns:1fr}
  .price-grid{grid-template-columns:1fr}
  .dash-metrics{grid-template-columns:1fr 1fr}
  .dash-g2{grid-template-columns:1fr}
  .hp-content{grid-template-columns:1fr}
  .hp-sidebar{display:none}
  .sidebar{display:none}
  .main-content{padding:16px}
  .hero{padding:90px 16px 50px}
}
</style>
</head>
<body>

