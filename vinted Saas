      <div class="fg" style="margin:0"><label>Email</label><input class="fi" id="auth-email" type="email" placeholder="ton@email.com"></div>
      <div class="fg" style="margin:0"><label>Mot de passe</label><input class="fi" id="auth-pw" type="password" placeholder="••••••••"></div>
      <div class="fg" id="auth-name-wrap" style="margin:0"><label>Prénom</label><input class="fi" id="auth-name" type="text" placeholder="Ton prénom"></div>
    </div>
    <button class="btn btn-g btn-full" id="auth-btn" onclick="doAuth()" style="font-size:14px;padding:12px">Créer mon compte gratuit →</button>
    <div style="text-align:center;margin-top:12px;font-size:12px;color:var(--mu)" id="auth-switch">
      Déjà un compte ? <span style="color:var(--p);cursor:pointer;font-weight:500" onclick="switchAuth()">Se connecter</span>
    </div>
  </div>
</div>

