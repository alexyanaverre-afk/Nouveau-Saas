<!-- ══════════════════════════════════════
     APP DASHBOARD
══════════════════════════════════════ -->
<div id="view-app">
  <!-- Topbar -->
  <div class="app-top">
    <div class="at-logo"><div class="logo-dot"></div>VintFlow</div>
    <div class="at-r">
      <span class="usage-text" id="top-usage"></span>
      <span class="plan-badge" id="top-plan">Gratuit</span>
      <div class="avatar" id="user-avatar" title="Mon compte">?</div>
      <button class="btn btn-sm btn-ol" onclick="logout()">Déconnexion</button>
    </div>
  </div>

  <div class="app-wrap">
    <!-- Sidebar -->
    <nav class="sidebar">
      <div class="sb-item ac" id="si-dashboard" onclick="showAppPage('dashboard',this)"><span class="sb-ico">▦</span>Dashboard</div>
      <div class="sb-item" id="si-generate" onclick="showAppPage('generate',this)"><span class="sb-ico">⚡</span>Générer annonce</div>
      <div class="sb-item" id="si-history" onclick="showAppPage('history',this)"><span class="sb-ico">🕐</span>Historique</div>
      <div class="sb-sep"></div>
      <div class="sb-item" id="si-settings" onclick="showAppPage('settings',this)"><span class="sb-ico">⚙️</span>Settings</div>
      <div class="sb-upgrade" id="sb-upgrade-box">
        <div class="sb-up-t">✨ Passer Premium</div>
        <div class="sb-up-d">Annonces illimitées + historique complet</div>
        <button class="btn btn-g btn-sm btn-full" onclick="showModal('upgrade-modal')">9€/mois</button>
      </div>
    </nav>

    <!-- Main -->
    <div class="main-content">

      <!-- ── DASHBOARD ── -->
      <div class="page-app ac" id="page-dashboard">
        <div class="page-hd">
          <div class="ph-t" id="dash-greeting">Bonjour 👋</div>
          <div class="ph-d">Voici un résumé de tes activités VintFlow</div>
        </div>
        <div class="dash-metrics">
          <div class="dash-mc"><div class="dm-l">Annonces générées</div><div class="dm-v" id="dm-total">0</div><div class="dm-s">ce mois-ci</div></div>
          <div class="dash-mc"><div class="dm-l">Score moyen</div><div class="dm-v" id="dm-score" style="color:var(--green)">—</div><div class="dm-s">sur 100</div></div>
          <div class="dash-mc"><div class="dm-l">Temps économisé</div><div class="dm-v" id="dm-time" style="color:var(--p)">0h</div><div class="dm-s">estimé (10min/annonce)</div></div>
        </div>
        <div class="dash-g2">
          <div class="card" style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:18px">
            <div class="card-title" style="font-size:14px">Dernières annonces</div>
            <div id="dash-recent"><div class="empty-state" style="padding:20px"><div style="font-size:32px;margin-bottom:8px">📭</div><div style="font-size:13px;color:var(--mu)">Aucune annonce générée</div></div></div>
          </div>
          <div class="card" style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:18px">
            <div class="card-title" style="font-size:14px">💡 Conseils du jour</div>
            <div class="tip-item"><div class="tip-t">Photographie sur fond blanc</div><div class="tip-d">Les annonces avec fond blanc ont 40% de plus de vues sur Vinted.</div></div>
            <div class="tip-item"><div class="tip-t">Prix légèrement rond</div><div class="tip-d">15€ se vend mieux que 16€. Les acheteurs filtrent par prix ronds.</div></div>
            <div class="tip-item"><div class="tip-t">Publie le soir</div><div class="tip-d">18h–21h = pic d'activité Vinted. Tes annonces fraîches seront plus visibles.</div></div>
          </div>
        </div>
      </div>

      <!-- ── GENERATE ── -->
      <div class="page-app" id="page-generate">
        <div class="page-hd">
          <div class="ph-t">⚡ Générer une annonce</div>
          <div class="ph-d">Remplis le formulaire — ton annonce est prête en 10 secondes</div>
        </div>
        <div class="limit-bar" id="limit-bar">
          <div style="font-size:12px;color:var(--mu)">Annonces ce mois</div>
          <div class="lb-track"><div class="lb-fill" id="lb-fill" style="width:0%"></div></div>
          <div class="lb-text"><strong id="lb-used">0</strong>/5</div>
        </div>
        <div class="gen-layout">
          <div class="gen-form-card">
            <div class="card-title">📝 Informations article</div>
            <div class="fi-row">
              <div class="fg"><label>Type d'article *</label>
                <select class="fi" id="g-type">
                  <option value="" disabled selected>Choisir...</option>
                  <optgroup label="Vêtements">
                    <option>Hoodie / Sweat</option><option>T-shirt</option><option>Veste / Manteau</option>
                    <option>Jean / Pantalon</option><option>Short</option><option>Robe / Jupe</option>
                    <option>Pull / Gilet</option><option>Chemise</option>
                  </optgroup>
                  <optgroup label="Chaussures">
                    <option>Sneakers</option><option>Bottines / Boots</option><option>Sandales</option><option>Mocassins</option>
                  </optgroup>
                  <optgroup label="Accessoires">
                    <option>Sac à main</option><option>Casquette / Bonnet</option><option>Ceinture</option><option>Montre</option>
                  </optgroup>
                </select>
              </div>
              <div class="fg"><label>Marque *</label><input class="fi" id="g-brand" type="text" placeholder="ex: Nike, Zara, H&M..."></div>
            </div>
            <div class="fi-row">
              <div class="fg"><label>Taille</label>
                <select class="fi" id="g-size">
                  <option value="">Non spécifiée</option>
                  <optgroup label="Vêtements">
                    <option>XS</option><option>S</option><option>M</option><option>L</option><option>XL</option><option>XXL</option>
                  </optgroup>
                  <optgroup label="Chaussures (EU)">
                    <option>36</option><option>37</option><option>38</option><option>39</option><option>40</option>
                    <option>41</option><option>42</option><option>43</option><option>44</option><option>45</option>
                  </optgroup>
                </select>
              </div>
              <div class="fg"><label>État *</label>
                <select class="fi" id="g-condition">
                  <option value="" disabled selected>Choisir...</option>
                  <option value="neuf_etiquette">Neuf avec étiquette</option>
                  <option value="neuf_sans">Neuf sans étiquette</option>
                  <option value="tres_bon">Très bon état</option>
                  <option value="bon">Bon état</option>
                  <option value="satisfaisant">État satisfaisant</option>
                </select>
              </div>
            </div>
            <div class="fi-row">
              <div class="fg"><label>Prix d'achat (€)</label><input class="fi" id="g-buy" type="number" placeholder="ex: 80" min="0"></div>
              <div class="fg"><label>Couleur / Détails</label><input class="fi" id="g-color" type="text" placeholder="ex: noir, vintage, cropped..."></div>
            </div>
            <div class="fg"><label>Infos supplémentaires</label><input class="fi" id="g-extra" type="text" placeholder="ex: jamais porté, taille grande, collector..."></div>
            <button class="btn btn-g btn-full" style="font-size:15px;padding:13px;margin-top:6px" id="gen-btn" onclick="generateListing()">
              ⚡ Générer mon annonce
            </button>
            <div style="font-size:11px;color:var(--mu);text-align:center;margin-top:8px">Powered by Claude AI · ~10 secondes</div>
          </div>

          <div class="gen-result-card">
            <div class="card-title">✨ Ton annonce</div>
            <div class="result-empty" id="result-empty">
              <div class="re-ico">✦</div>
              <div class="re-t">Prêt à générer</div>
              <div class="re-d">Remplis le formulaire et clique sur "Générer mon annonce" pour voir le résultat ici.</div>
            </div>
            <div id="gen-loading" class="hidden">
              <div class="shimmer sh-t"></div>
              <div class="shimmer sh-d" style="margin-top:16px"></div>
              <div class="shimmer sh-d2"></div>
              <div class="shimmer sh-d3"></div>
              <div class="shimmer sh-d" style="margin-top:16px"></div>
              <div class="shimmer sh-d2"></div>
              <div style="display:flex;align-items:center;gap:8px;margin-top:16px;font-size:12px;color:var(--mu)"><div class="spinner" style="border-color:rgba(99,102,241,.2);border-top-color:var(--p)"></div> Génération en cours...</div>
            </div>
            <div class="result-content" id="result-content">
              <div class="res-block">
                <div class="rb-label">Titre optimisé <button class="rb-copy" onclick="copyField('res-title')">Copier</button></div>
                <div class="rb-title" id="res-title"></div>
              </div>
              <div class="res-block">
                <div class="rb-label">Description <button class="rb-copy" onclick="copyField('res-desc')">Copier</button></div>
                <div class="rb-text" id="res-desc"></div>
              </div>
              <div class="res-block">
                <div class="rb-label">Hashtags <button class="rb-copy" onclick="copyField('res-tags')">Copier</button></div>
                <div class="tags-wrap" id="res-tags-wrap"></div>
                <div class="hidden" id="res-tags"></div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                <div class="res-block">
                  <div class="rb-label">Prix conseillé</div>
                  <div class="rb-price" id="res-price"></div>
                  <div class="rb-price-note" id="res-price-note"></div>
                </div>
                <div class="res-block">
                  <div class="rb-label">Optimisation</div>
                  <div class="score-row">
                    <div class="score-circle" id="score-circle">
                      <div class="score-inner" id="score-val">0</div>
                    </div>
                    <div>
                      <div class="score-feedback" id="score-feedback"></div>
                      <div class="score-label" id="score-label"></div>
                    </div>
                  </div>
                </div>
              </div>
              <div style="display:flex;gap:8px;margin-top:4px">
                <button class="btn btn-p btn-sm" style="flex:1;justify-content:center" onclick="copyAll()">📋 Tout copier</button>
                <button class="btn btn-ghost btn-sm" onclick="duplicateCurrent()">⊕ Dupliquer</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── HISTORY ── -->
      <div class="page-app" id="page-history">
        <div class="page-hd">
          <div class="ph-t">🕐 Historique</div>
          <div class="ph-d">Toutes tes annonces générées</div>
        </div>
        <div id="hist-content"></div>
      </div>

      <!-- ── SETTINGS ── */
      <div class="page-app" id="page-settings">
        <div class="page-hd">
          <div class="ph-t">⚙️ Settings</div>
          <div class="ph-d">Ton compte et tes préférences</div>
        </div>
        <div class="settings-grid">
          <div class="settings-card">
            <div class="sc-t">Mon compte</div>
            <div class="srow"><div><div class="sr-l">Email</div><div class="sr-d" id="set-email">—</div></div></div>
            <div class="srow"><div><div class="sr-l">Prénom</div><div class="sr-d" id="set-name">—</div></div></div>
            <div class="srow"><div><div class="sr-l">Plan actuel</div><div class="sr-d" id="set-plan">Gratuit</div></div><span class="plan-badge" id="set-plan-badge">Gratuit</span></div>
            <div class="srow"><div><div class="sr-l">Annonces ce mois</div><div class="sr-d" id="set-usage">0/5</div></div></div>
            <button class="btn btn-g btn-full" style="margin-top:16px" onclick="showModal('upgrade-modal')" id="upgrade-btn-settings">✨ Passer Premium — 9€/mois</button>
          </div>
          <div class="settings-card">
            <div class="sc-t">Préférences</div>
            <div class="srow"><div><div class="sr-l">Langue de génération</div><div class="sr-d">Français</div></div><select class="fi" style="width:auto;padding:5px 9px"><option selected>Français</option><option>Néerlandais</option><option>Anglais</option></select></div>
            <div class="srow"><div><div class="sr-l">Style description</div><div class="sr-d">Court et percutant</div></div><select class="fi" id="set-style" style="width:auto;padding:5px 9px"><option value="court" selected>Court</option><option value="detaille">Détaillé</option><option value="storytelling">Storytelling</option></select></div>
            <div class="srow"><div><div class="sr-l">Réinitialiser les données</div><div class="sr-d">Supprime l'historique local</div></div><button class="btn btn-sm" style="background:#FEF2F2;color:var(--red);border:1px solid #FECACA" onclick="clearData()">Effacer</button></div>
          </div>
        </div>
      </div>

    </div><!-- end main-content -->
  </div><!-- end app-wrap -->
</div><!-- end view-app -->

<script>
// ─────────────────────────────────────────────
// CONFIG
// ─────────────────────────────────────────────
const CLAUDE_MODEL = 'claude-sonnet-4-20250514';
const FREE_LIMIT = 5;

// ─────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────
let state = {
  user: null,
  isPremium: false,
  listings: [],
  usageThisMonth: 0,
  currentListing: null,
  authMode: 'signup'
};

// ─────────────────────────────────────────────
// STORAGE
// ─────────────────────────────────────────────
function save() {
  try { localStorage.setItem('vintflow_state', JSON.stringify(state)); } catch(e) {}
}
function load() {
  try {
    const d = localStorage.getItem('vintflow_state');
    if (d) {
      const parsed = JSON.parse(d);
      // Reset monthly usage if new month
      const saved = localStorage.getItem('vintflow_month');
      const now = new Date().toISOString().slice(0,7);
      if (saved !== now) {
        parsed.usageThisMonth = 0;
        localStorage.setItem('vintflow_month', now);
      }
      state = {...state, ...parsed};
    } else {
      localStorage.setItem('vintflow_month', new Date().toISOString().slice(0,7));
    }
  } catch(e) {}
}

// ─────────────────────────────────────────────
// VIEW SWITCHING
// ─────────────────────────────────────────────
function showView(v) {
  document.getElementById('view-landing').classList.remove('show');
  document.getElementById('view-app').classList.remove('show');
  document.getElementById('view-' + v).classList.add('show');
}

function showAppPage(name, el) {
  document.querySelectorAll('.page-app').forEach(p => p.classList.remove('ac'));
  document.querySelectorAll('.sb-item').forEach(s => s.classList.remove('ac'));
  const pg = document.getElementById('page-' + name);
  if (pg) pg.classList.add('ac');
  if (el) el.classList.add('ac');
  window.scrollTo(0, 0);
  if (name === 'dashboard') loadDashboard();
  if (name === 'history') loadHistory();
  if (name === 'settings') loadSettings();
  if (name === 'generate') updateLimitBar();
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────
function openSignup() { state.authMode = 'signup'; setAuthMode('signup'); showModal('auth-modal'); }
function openLogin() { state.authMode = 'login'; setAuthMode('login'); showModal('auth-modal'); }
function switchAuth() {
  state.authMode = state.authMode === 'signup' ? 'login' : 'signup';
  setAuthMode(state.authMode);
}
function setAuthMode(mode) {
  const isLogin = mode === 'login';
  document.getElementById('auth-ico').textContent = isLogin ? '👋' : '🎉';
  document.getElementById('auth-title').textContent = isLogin ? 'Bon retour !' : 'Créer mon compte';
  document.getElementById('auth-desc').textContent = isLogin ? 'Connecte-toi à ton compte VintFlow.' : '5 annonces gratuites t\'attendent. Sans carte bancaire.';
  document.getElementById('auth-btn').textContent = isLogin ? 'Se connecter →' : 'Créer mon compte gratuit →';
  document.getElementById('auth-name-wrap').style.display = isLogin ? 'none' : 'block';
  document.getElementById('auth-switch').innerHTML = isLogin
    ? 'Pas encore de compte ? <span style="color:var(--p);cursor:pointer;font-weight:500" onclick="switchAuth()">S\'inscrire gratuitement</span>'
    : 'Déjà un compte ? <span style="color:var(--p);cursor:pointer;font-weight:500" onclick="switchAuth()">Se connecter</span>';
}
function doAuth() {
  const email = document.getElementById('auth-email').value.trim();
  const pw = document.getElementById('auth-pw').value.trim();
  if (!email || !pw) { showToast('Remplis tous les champs', 'error'); return; }
  if (!email.includes('@')) { showToast('Email invalide', 'error'); return; }
  if (pw.length < 6) { showToast('Mot de passe trop court (6 min)', 'error'); return; }
  const name = document.getElementById('auth-name').value.trim() || email.split('@')[0];
  state.user = { email, name, createdAt: new Date().toISOString() };
  save();
  closeModal('auth-modal');
  enterApp();
  showToast(state.authMode === 'signup' ? '🎉 Bienvenue sur VintFlow !' : '👋 Bon retour !', 'success');
}
function logout() {
  if (!confirm('Se déconnecter ?')) return;
  showView('landing');
  showToast('Déconnecté', '');
}
function enterApp() {
  showView('app');
  updateTopBar();
  loadDashboard();
  updateLimitBar();
  // Show/hide upgrade box
  document.getElementById('sb-upgrade-box').style.display = state.isPremium ? 'none' : 'block';
  document.getElementById('upgrade-btn-settings').style.display = state.isPremium ? 'none' : 'block';
}

// ─────────────────────────────────────────────
// TOP BAR
// ─────────────────────────────────────────────
function updateTopBar() {
  if (!state.user) return;
  const initials = (state.user.name || '?')[0].toUpperCase();
  document.getElementById('user-avatar').textContent = initials;
  const planEl = document.getElementById('top-plan');
  planEl.textContent = state.isPremium ? '⭐ Premium' : 'Gratuit';
  planEl.className = 'plan-badge' + (state.isPremium ? ' premium' : '');
  if (!state.isPremium) {
    document.getElementById('top-usage').textContent = `${state.usageThisMonth}/${FREE_LIMIT} annonces`;
  } else {
    document.getElementById('top-usage').textContent = 'Annonces illimitées';
  }
}

// ─────────────────────────────────────────────
// LIMIT BAR
// ─────────────────────────────────────────────
function updateLimitBar() {
  const bar = document.getElementById('limit-bar');
  if (state.isPremium) { bar.style.display = 'none'; return; }
  bar.style.display = 'flex';
  const used = state.usageThisMonth;
  const pct = Math.min((used / FREE_LIMIT) * 100, 100);
  const fill = document.getElementById('lb-fill');
  fill.style.width = pct + '%';
  fill.className = 'lb-fill' + (pct >= 100 ? ' full' : pct >= 80 ? ' warn' : '');
  document.getElementById('lb-used').textContent = used;
}

// ─────────────────────────────────────────────
// GENERATE LISTING — CLAUDE API
// ─────────────────────────────────────────────
async function generateListing() {
  if (!state.isPremium && state.usageThisMonth >= FREE_LIMIT) {
    showModal('upgrade-modal'); return;
  }
  const type = document.getElementById('g-type').value;
  const brand = document.getElementById('g-brand').value.trim();
  const size = document.getElementById('g-size').value;
  const condition = document.getElementById('g-condition').value;
  const buyPrice = document.getElementById('g-buy').value;
  const color = document.getElementById('g-color').value.trim();
  const extra = document.getElementById('g-extra').value.trim();

  if (!type || !brand || !condition) {
    showToast('Remplis au moins : type, marque et état', 'error'); return;
  }

  // UI loading
  document.getElementById('result-empty').classList.add('hidden');
  document.getElementById('result-content').classList.remove('show');
  document.getElementById('result-content').style.display = 'none';
  document.getElementById('gen-loading').classList.remove('hidden');
  const btn = document.getElementById('gen-btn');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Génération en cours...';

  const condMap = {neuf_etiquette:'Neuf avec étiquette',neuf_sans:'Neuf sans étiquette',tres_bon:'Très bon état',bon:'Bon état',satisfaisant:'État satisfaisant'};
  const condLabel = condMap[condition] || condition;

  const prompt = `Tu es un expert en vente sur Vinted. Génère une annonce optimisée pour l'algorithme Vinted.

Article :
- Type : ${type}
- Marque : ${brand}
- Taille : ${size || 'non précisée'}
- État : ${condLabel}
- Prix d'achat : ${buyPrice ? buyPrice + '€' : 'non précisé'}
- Couleur/détails : ${color || 'non précisé'}
- Infos supplémentaires : ${extra || 'aucune'}

Génère EXACTEMENT ce JSON (rien d'autre, pas de markdown) :
{
  "titre": "Titre SEO optimisé max 80 caractères, percutant, avec marque + type + taille + état clé",
  "description": "Description 3-4 phrases max, naturelle, persuasive, mentionne les points forts, incite à acheter vite",
  "hashtags": ["hashtag1","hashtag2",...], // 20 à 25 hashtags sans # , mélange marque/type/style/couleur/taille
  "prix": 25, // nombre entier en euros, calculé selon état et prix d'achat (si neuf = 60-70% prix achat, très bon = 40-50%, bon = 25-35%)
  "prix_note": "Explication courte du prix en 1 phrase",
  "score": 88, // score optimisation sur 100 selon qualité des infos fournies
  "score_feedback": "Excellent" // ou "Très bon" ou "Bon" ou "À améliorer"
}`;

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': '',  // handled by proxy
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: CLAUDE_MODEL,
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await resp.json();
    let raw = data.content?.[0]?.text || '';

    // Parse JSON from response
    let listing;
    try {
      raw = raw.replace(/```json?/g, '').replace(/```/g, '').trim();
      listing = JSON.parse(raw);
    } catch(e) {
      // Fallback: extract JSON with regex
      const match = raw.match(/\{[\s\S]*\}/);
      if (match) listing = JSON.parse(match[0]);
      else throw new Error('Parse error');
    }

    // Display result
    displayListing(listing);

    // Save to history
    const entry = {
      id: Date.now(),
      ...listing,
      meta: { type, brand, size, condition: condLabel, color, buyPrice, extra },
      createdAt: new Date().toISOString()
    };
    state.listings.unshift(entry);
    if (state.listings.length > 100) state.listings.pop();
    state.usageThisMonth++;
    state.currentListing = entry;
    save();
    updateTopBar();
    updateLimitBar();
    showToast('✨ Ton annonce est prête !', 'success');

  } catch(err) {
    console.error(err);
    // Fallback mock if API fails
    const fallback = generateMock(type, brand, size, condLabel, buyPrice, color);
    displayListing(fallback);
    const entry = { id: Date.now(), ...fallback, meta: { type, brand, size, condition: condLabel, color, buyPrice, extra }, createdAt: new Date().toISOString() };
    state.listings.unshift(entry);
    state.usageThisMonth++;
    state.currentListing = entry;
    save();
    updateTopBar();
    updateLimitBar();
    showToast('✨ Annonce générée', 'success');
  }

  document.getElementById('gen-loading').classList.add('hidden');
  btn.disabled = false;
  btn.innerHTML = '⚡ Générer mon annonce';
}

// Fallback mock generator
function generateMock(type, brand, size, condition, buyPrice, color) {
  const condMap2 = {'Neuf avec étiquette':0.65,'Neuf sans étiquette':0.55,'Très bon état':0.45,'Bon état':0.30,'État satisfaisant':0.20};
  const ratio = condMap2[condition] || 0.4;
  const prix = buyPrice ? Math.round(parseFloat(buyPrice) * ratio) : Math.floor(Math.random() * 30) + 10;
  const sizeStr = size ? `— Taille ${size} ` : '';
  const colorStr = color ? `${color} ` : '';
  return {
    titre: `${brand} ${type} ${sizeStr}${colorStr}— ${condition}`,
    description: `${type} ${brand} en ${condition.toLowerCase()}. ${size ? `Taille ${size}.` : ''} ${color ? `Coloris ${color}.` : ''} ${buyPrice ? `Payé ${buyPrice}€.` : ''} Article soigneusement entretenu. N'hésitez pas à me faire une offre ! 😊`,
    hashtags: [type.toLowerCase().replace(/\s/g,''),brand.toLowerCase(),condition.toLowerCase().replace(/\s/g,''),'vinted','mode','seconde_main','friperie','tendance','vintage','style','fashion','vetement','look','outfit','preloved',color||'mode',size||'m','fripe','bonplan','acheter'],
    prix,
    prix_note: buyPrice ? `${Math.round(ratio*100)}% du prix d'achat (${buyPrice}€)` : 'Prix basé sur le marché Vinted',
    score: 70 + Math.floor(Math.random() * 20),
    score_feedback: 'Très bon'
  };
}

// Display listing in UI
function displayListing(l) {
  document.getElementById('res-title').textContent = l.titre || '';
  document.getElementById('res-desc').textContent = l.description || '';

  const tags = Array.isArray(l.hashtags) ? l.hashtags : [];
  document.getElementById('res-tags').textContent = tags.map(t => '#' + t).join(' ');
  document.getElementById('res-tags-wrap').innerHTML = tags.slice(0, 20).map(t =>
    `<span class="tag">#${t}</span>`
  ).join('');

  document.getElementById('res-price').textContent = (l.prix || '?') + '€';
  document.getElementById('res-price-note').textContent = l.prix_note || '';

  const score = parseInt(l.score) || 75;
  document.getElementById('score-val').textContent = score;
  document.getElementById('score-circle').style.setProperty('--pct', `${score}%`);
  document.getElementById('score-feedback').textContent = l.score_feedback || 'Bon';
  document.getElementById('score-label').textContent = score >= 90 ? 'Excellent 🎯' : score >= 75 ? 'Très bon ✓' : 'À améliorer';

  document.getElementById('result-empty').classList.add('hidden');
  document.getElementById('result-content').style.display = 'block';
  setTimeout(() => document.getElementById('result-content').classList.add('show'), 10);
}

// ─────────────────────────────────────────────
// COPY
// ─────────────────────────────────────────────
function copyField(id) {
  const el = document.getElementById(id);
  const text = el ? el.textContent : '';
  navigator.clipboard.writeText(text).then(() => {
    // Find copy button for this field
    const container = el.closest('.res-block');
    const btn = container ? container.querySelector('.rb-copy') : null;
    if (btn) {
      btn.textContent = '✓ Copié';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'Copier'; btn.classList.remove('copied'); }, 1800);
    }
    showToast('Copié dans le presse-papier', 'success');
  }).catch(() => showToast('Copie impossible', 'error'));
}

function copyAll() {
  if (!state.currentListing) return;
  const l = state.currentListing;
  const text = `${l.titre}\n\n${l.description}\n\n${l.hashtags.map(t=>'#'+t).join(' ')}\n\nPrix : ${l.prix}€`;
  navigator.clipboard.writeText(text).then(() => showToast('📋 Tout copié !', 'success'));
}

function duplicateCurrent() {
  if (!state.isPremium) { showModal('upgrade-modal'); return; }
  if (!state.currentListing) return;
  const l = state.currentListing;
  if (l.meta) {
    document.getElementById('g-type').value = l.meta.type || '';
    document.getElementById('g-brand').value = l.meta.brand || '';
    document.getElementById('g-size').value = l.meta.size || '';
    document.getElementById('g-buy').value = l.meta.buyPrice || '';
    document.getElementById('g-color').value = l.meta.color || '';
    document.getElementById('g-extra').value = l.meta.extra || '';
  }
  showToast('Formulaire rempli avec cette annonce', '');
}

// ─────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────
function loadDashboard() {
  if (!state.user) return;
  const name = state.user.name || 'toi';
  const hour = new Date().getHours();
  const greeting = hour < 12 ? 'Bonjour' : hour < 18 ? 'Bonsoir' : 'Bonsoir';
  document.getElementById('dash-greeting').textContent = `${greeting} ${name} 👋`;
  document.getElementById('dm-total').textContent = state.usageThisMonth;
  const scores = state.listings.slice(0, 10).map(l => parseInt(l.score) || 75);
  const avg = scores.length ? Math.round(scores.reduce((a,b)=>a+b,0)/scores.length) : null;
  document.getElementById('dm-score').textContent = avg ? avg + '/100' : '—';
  const mins = state.usageThisMonth * 10;
  document.getElementById('dm-time').textContent = mins >= 60 ? Math.floor(mins/60) + 'h' + (mins%60?String(mins%60).padStart(2,'0'):'') : mins + 'min';

  // Recent
  const recentEl = document.getElementById('dash-recent');
  if (!state.listings.length) {
    recentEl.innerHTML = '<div class="empty-state" style="padding:20px"><div style="font-size:28px;margin-bottom:6px">📭</div><div style="font-size:13px;color:var(--mu)">Aucune annonce générée</div></div>';
  } else {
    recentEl.innerHTML = state.listings.slice(0, 5).map(l => `
      <div class="recent-item">
        <div class="ri-ico">${getTypeIco(l.meta?.type)}</div>
        <div class="ri-inf">
          <div class="ri-t">${l.titre}</div>
          <div class="ri-s">${l.meta?.brand || ''} · ${l.meta?.condition || ''} · ${l.prix}€</div>
        </div>
        <div class="ri-score">${l.score}/100</div>
      </div>`).join('');
  }
}

function getTypeIco(type) {
  if (!type) return '👕';
  if (type.includes('Nike')||type.includes('Sneaker')||type.includes('haussure')||type.toLowerCase().includes('sneaker')) return '👟';
  if (type.includes('Sac')) return '👜';
  if (type.includes('Veste')||type.includes('Manteau')) return '🧥';
  if (type.includes('Hoodie')||type.includes('Sweat')) return '🧥';
  if (type.includes('Robe')||type.includes('Jupe')) return '👗';
  if (type.includes('Jean')||type.includes('Pantalon')||type.includes('Short')) return '👖';
  return '👕';
}

// ─────────────────────────────────────────────
// HISTORY
// ─────────────────────────────────────────────
function loadHistory() {
  const el = document.getElementById('hist-content');
  if (!state.isPremium && !state.listings.length) {
    el.innerHTML = `<div class="empty-state"><div class="es-ico">🔒</div><div class="es-t">Historique Premium</div><div class="es-d">L'historique complet est disponible avec le plan Premium. Commence à générer des annonces gratuitement !</div><button class="btn btn-g" onclick="showModal('upgrade-modal')">✨ Passer Premium — 9€/mois</button></div>`;
    return;
  }
  if (!state.listings.length) {
    el.innerHTML = `<div class="empty-state"><div class="es-ico">📭</div><div class="es-t">Aucune annonce encore</div><div class="es-d">Génère ta première annonce pour la voir apparaître ici.</div><button class="btn btn-p" onclick="showAppPage('generate',document.getElementById('si-generate'))">⚡ Générer ma première annonce</button></div>`;
    return;
  }
  el.innerHTML = '<div class="hist-grid">' + state.listings.map(l => `
    <div class="hist-card">
      <div class="hc-top">
        <div class="hc-title">${l.titre}</div>
        <div class="hc-score">${l.score}/100</div>
      </div>
      <div class="hc-desc">${l.description}</div>
      <div class="hc-meta">
        ${l.meta?.brand ? `<span class="hc-tag">${l.meta.brand}</span>` : ''}
        ${l.meta?.condition ? `<span class="hc-tag">${l.meta.condition}</span>` : ''}
        ${l.meta?.size ? `<span class="hc-tag">T. ${l.meta.size}</span>` : ''}
        <span class="hc-tag">${new Date(l.createdAt).toLocaleDateString('fr-BE')}</span>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div class="hc-price">${l.prix}€</div>
        <div class="hc-actions">
          <button class="btn btn-sm btn-ghost" onclick="loadFromHistory(${l.id})">📋 Copier tout</button>
          <button class="btn btn-sm btn-ol" onclick="deleteFromHistory(${l.id})">✕</button>
        </div>
      </div>
    </div>`).join('') + '</div>';
}

function loadFromHistory(id) {
  const l = state.listings.find(x => x.id === id);
  if (!l) return;
  state.currentListing = l;
  displayListing(l);
  showAppPage('generate', document.getElementById('si-generate'));
  copyAll();
}

function deleteFromHistory(id) {
  state.listings = state.listings.filter(x => x.id !== id);
  save();
  loadHistory();
  showToast('Annonce supprimée', '');
}

// ─────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────
function loadSettings() {
  if (!state.user) return;
  document.getElementById('set-email').textContent = state.user.email || '—';
  document.getElementById('set-name').textContent = state.user.name || '—';
  const isPrem = state.isPremium;
  document.getElementById('set-plan').textContent = isPrem ? 'Premium' : 'Gratuit';
  const badgeEl = document.getElementById('set-plan-badge');
  badgeEl.textContent = isPrem ? '⭐ Premium' : 'Gratuit';
  badgeEl.className = 'plan-badge' + (isPrem ? ' premium' : '');
  document.getElementById('set-usage').textContent = isPrem ? 'Illimité' : `${state.usageThisMonth}/5`;
  document.getElementById('upgrade-btn-settings').style.display = isPrem ? 'none' : 'flex';
}

function clearData() {
  if (!confirm('Supprimer tout l\'historique local ? Cette action est irréversible.')) return;
  state.listings = [];
  state.usageThisMonth = 0;
  save();
  loadSettings();
  showToast('Données effacées', '');
}

// ─────────────────────────────────────────────
// PREMIUM
// ─────────────────────────────────────────────
function activatePremium() {
  // In production: redirect to Stripe payment link
  // For demo: activate directly
  state.isPremium = true;
  save();
  closeModal('upgrade-modal');
  document.getElementById('sb-upgrade-box').style.display = 'none';
  document.getElementById('upgrade-btn-settings').style.display = 'none';
  updateTopBar();
  updateLimitBar();
  loadSettings();
  showToast('🎉 Bienvenue dans Premium !', 'success');
  // In production, replace this with:
  // window.open('https://buy.stripe.com/your-link', '_blank');
}

// ─────────────────────────────────────────────
// MODALS & TOASTS
// ─────────────────────────────────────────────
function showModal(id) { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) m.classList.remove('show'); });
});

let toastTimer;
function showToast(msg, type) {
  const existing = document.querySelector('.toast');
  if (existing) existing.remove();
  clearTimeout(toastTimer);
  const t = document.createElement('div');
  t.className = 'toast' + (type ? ' ' + type : '');
  t.innerHTML = msg;
  document.body.appendChild(t);
  toastTimer = setTimeout(() => { if (t.parentNode) t.remove(); }, 3000);
}

// ─────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  load();
  if (state.user) {
    enterApp();
  } else {
    showView('landing');
  }
});
</script>
</body>
</html>
