      <div class="price-feat"><span class="pf-ok">✓</span> Annonces illimitées</div>
      <div class="price-feat"><span class="pf-ok">✓</span> Historique complet</div>
      <div class="price-feat"><span class="pf-ok">✓</span> Score d'optimisation avancé</div>
      <div class="price-feat"><span class="pf-ok">✓</span> Duplication rapide</div>
      <button class="btn btn-g btn-full" style="margin-top:18px" onclick="openSignup()">Commencer 9€/mois</button>
    </div>
  </div>
</div>

<div class="footer">
  <div class="footer-logo"><div class="logo-dot"></div>VintFlow</div>
  <div>© 2025 VintFlow · Vends 3x plus vite sur Vinted</div>
</div>

</div><!-- end landing -->

<!-- ══════════════════════════════════════
     AUTH MODAL
══════════════════════════════════════ -->
<div class="modal-overlay" id="auth-modal">
  <div class="modal" style="position:relative">
    <button class="modal-close" onclick="closeModal('auth-modal')">✕</button>
    <div class="modal-ico" id="auth-ico">🎉</div>
    <div class="modal-t" id="auth-title">Créer mon compte</div>
    <div class="modal-d" id="auth-desc">5 annonces gratuites t'attendent. Sans carte bancaire.</div>
